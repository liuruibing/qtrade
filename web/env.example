# AI API 配置示例
# 复制此文件为 .env 并填入你的API密钥

# OpenAI 配置
VITE_OPENAI_API_KEY=your_openai_api_key_here
VITE_OPENAI_BASE_URL=https://api.openai.com/v1

# Claude 配置
VITE_CLAUDE_API_KEY=your_claude_api_key_here
VITE_CLAUDE_BASE_URL=https://api.anthropic.com/v1

# 通义千问配置
VITE_QWEN_API_KEY=your_qwen_api_key_here
VITE_QWEN_BASE_URL=https://dashscope.aliyuncs.com/api/v1

# 文心一言配置
VITE_ERNIE_API_KEY=your_ernie_api_key_here
VITE_ERNIE_SECRET_KEY=your_ernie_secret_key_here
VITE_ERNIE_BASE_URL=https://aip.baidubce.com
